# Copy this file to .env at the project root and fill in the values.
# NEVER commit .env — it is in .gitignore.

# --- OpenAI ---
OPENAI_API_KEY=sk-...

# --- Database (Postgres + pgvector) ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/ragdb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ragdb

# --- Langfuse (self-hosted observability) ---
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=http://langfuse:3000

# --- App ---
DEBUG=false

# --- Authorization (frontend) ---
# Comma-separated list of Google emails allowed to log in.
# Leave empty to allow any Google account (not recommended for production).
ALLOWED_EMAILS=you@gmail.com,recruiter@company.com
NEXTAUTH_SECRET=replace-with-openssl-rand-base64-32
NEXTAUTH_URL=https://rag.yourdomain.com
